<span id="cb3-35">    <span class="at" style="color: #657422;">breaks =</span> <span class="fu" style="color: #4758AB;">c</span>(<span class="dv" style="color: #AD0000;">5</span>, <span class="dv" style="color: #AD0000;">10</span>, <span class="dv" style="color: #AD0000;">15</span>, <span class="dv" style="color: #AD0000;">30</span>, <span class="dv" style="color: #AD0000;">60</span>, <span class="dv" style="color: #AD0000;">120</span>, <span class="dv" style="color: #AD0000;">360</span>, <span class="dv" style="color: #AD0000;">720</span>, <span class="dv" style="color: #AD0000;">1440</span>),</span>
<span id="cb3-36">    <span class="at" style="color: #657422;">labels =</span> <span class="fu" style="color: #4758AB;">c</span>(<span class="st" style="color: #20794D;">"5 min"</span>, <span class="st" style="color: #20794D;">"10"</span>, <span class="st" style="color: #20794D;">"15"</span>, <span class="st" style="color: #20794D;">"30"</span>, <span class="st" style="color: #20794D;">"1h"</span>, <span class="st" style="color: #20794D;">"2h"</span>, <span class="st" style="color: #20794D;">"6h"</span>, <span class="st" style="color: #20794D;">"12h"</span>, <span class="st" style="color: #20794D;">"24h"</span>)</span>
<span id="cb3-37">  ) <span class="sc" style="color: #5E5E5E;">+</span></span>
<span id="cb3-38">  <span class="fu" style="color: #4758AB;">scale_y_log10</span>() <span class="sc" style="color: #5E5E5E;">+</span></span>
<span id="cb3-39">  <span class="fu" style="color: #4758AB;">scale_color_manual</span>(</span>
<span id="cb3-40">    <span class="at" style="color: #657422;">values =</span> palette_idf,</span>
<span id="cb3-41">    <span class="at" style="color: #657422;">name   =</span> <span class="st" style="color: #20794D;">"Période de</span><span class="sc" style="color: #5E5E5E;">\n</span><span class="st" style="color: #20794D;">retour (ans)"</span></span>
<span id="cb3-42">  ) <span class="sc" style="color: #5E5E5E;">+</span></span>
<span id="cb3-43">  <span class="fu" style="color: #4758AB;">labs</span>(</span>
