<section id="formule-idf-de-montana" class="level2">
<h2 class="anchored" data-anchor-id="formule-idf-de-montana">Formule IDF de Montana</h2>
<p>La formule de <strong>Montana</strong> est l’expression analytique la plus utilisée pour les courbes IDF :</p>
<p><img src="https://latex.codecogs.com/png.latex?I(D,%20T)%20=%20a(T)%20%5Ccdot%20D%5E%7B-b(T)%7D"></p>
<p>où <img src="https://latex.codecogs.com/png.latex?I"> est l’intensité (mm/h), <img src="https://latex.codecogs.com/png.latex?D"> la durée (h), et <img src="https://latex.codecogs.com/png.latex?a(T)">, <img src="https://latex.codecogs.com/png.latex?b(T)"> des paramètres dépendants de la période de retour <img src="https://latex.codecogs.com/png.latex?T">.</p>
<div class="cell">
<details>
<summary>Code</summary>
<div class="sourceCode cell-code" id="cb4" style="background: #f1f3f5;"><pre class="sourceCode r code-with-copy"><code class="sourceCode r"><span id="cb4-1"><span class="co" style="color: #5E5E5E;"># Ajustement des paramètres de Montana par régression</span></span>
<span id="cb4-2">ajuster_montana <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="cf" style="color: #003B4F;">function</span>(intensites, durees_h) {</span>
<span id="cb4-3">  log_durees <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="fu" style="color: #4758AB;">log</span>(durees_h)</span>
<span id="cb4-4">  log_intens <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="fu" style="color: #4758AB;">log</span>(intensites)</span>
<span id="cb4-5">  </span>
<span id="cb4-6">  fit <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="fu" style="color: #4758AB;">lm</span>(log_intens <span class="sc" style="color: #5E5E5E;">~</span> log_durees)</span>
<span id="cb4-7">  b   <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="sc" style="color: #5E5E5E;">-</span><span class="fu" style="color: #4758AB;">coef</span>(fit)[<span class="dv" style="color: #AD0000;">2</span>]</span>
<span id="cb4-8">  a   <span class="ot" style="color: #003B4F;">&lt;-</span> <span class="fu" style="color: #4758AB;">exp</span>(<span class="fu" style="color: #4758AB;">coef</span>(fit)[<span class="dv" style="color: #AD0000;">1</span>])</span>
<span id="cb4-9">  </span>
<span id="cb4-10">  <span class="fu" style="color: #4758AB;">return</span>(<span class="fu" style="color: #4758AB;">list</span>(<span class="at" style="color: #657422;">a =</span> a, <span class="at" style="color: #657422;">b =</span> b, <span class="at" style="color: #657422;">r2 =</span> <span class="fu" style="color: #4758AB;">summary</span>(fit)<span class="sc" style="color: #5E5E5E;">$</span>r.squared))</span>
<span id="cb4-11">}</span>
<span id="cb4-12"></span>
<span id="cb4-13"><span class="co" style="color: #5E5E5E;"># Calculer pour chaque période de retour</span></span>
<span id="cb4-14">montana_params <span class="ot" style="color: #003B4F;">&lt;-</span> idf_long <span class="sc" style="color: #5E5E5E;">|&gt;</span></span>
<span id="cb4-15">  <span class="fu" style="color: #4758AB;">mutate</span>(<span class="at" style="color: #657422;">duree_h =</span> duree <span class="sc" style="color: #5E5E5E;">/</span> <span class="dv" style="color: #AD0000;">60</span>) <span class="sc" style="color: #5E5E5E;">|&gt;</span></span>
<span id="cb4-16">  <span class="fu" style="color: #4758AB;">group_by</span>(periode_retour) <span class="sc" style="color: #5E5E5E;">|&gt;</span></span>
<span id="cb4-17">  <span class="fu" style="color: #4758AB;">summarise</span>(</span>
<span id="cb4-18">    <span class="at" style="color: #657422;">params =</span> <span class="fu" style="color: #4758AB;">list</span>(<span class="fu" style="color: #4758AB;">ajuster_montana</span>(intensite, duree_h)),</span>
<span id="cb4-19">    <span class="at" style="color: #657422;">.groups =</span> <span class="st" style="color: #20794D;">"drop"</span></span>
<span id="cb4-20">  ) <span class="sc" style="color: #5E5E5E;">|&gt;</span></span>
<span id="cb4-21">  <span class="fu" style="color: #4758AB;">mutate</span>(</span>
<span id="cb4-22">    <span class="at" style="color: #657422;">a  =</span> <span class="fu" style="color: #4758AB;">sapply</span>(params, <span class="st" style="color: #20794D;">`</span><span class="at" style="color: #657422;">[[</span><span class="st" style="color: #20794D;">`</span>, <span class="st" style="color: #20794D;">"a"</span>),</span>
<span id="cb4-23">    <span class="at" style="color: #657422;">b  =</span> <span class="fu" style="color: #4758AB;">sapply</span>(params, <span class="st" style="color: #20794D;">`</span><span class="at" style="color: #657422;">[[</span><span class="st" style="color: #20794D;">`</span>, <span class="st" style="color: #20794D;">"b"</span>),</span>
<span id="cb4-24">    <span class="at" style="color: #657422;">r2 =</span> <span class="fu" style="color: #4758AB;">sapply</span>(params, <span class="st" style="color: #20794D;">`</span><span class="at" style="color: #657422;">[[</span><span class="st" style="color: #20794D;">`</span>, <span class="st" style="color: #20794D;">"r2"</span>)</span>
<span id="cb4-25">  ) <span class="sc" style="color: #5E5E5E;">|&gt;</span></span>
<span id="cb4-26">  <span class="fu" style="color: #4758AB;">select</span>(<span class="sc" style="color: #5E5E5E;">-</span>params)</span>
<span id="cb4-27"></span>
<span id="cb4-28">knitr<span class="sc" style="color: #5E5E5E;">::</span><span class="fu" style="color: #4758AB;">kable</span>(</span>
<span id="cb4-29">  montana_params,</span>
<span id="cb4-30">  <span class="at" style="color: #657422;">digits  =</span> <span class="dv" style="color: #AD0000;">3</span>,</span>
<span id="cb4-31">  <span class="at" style="color: #657422;">caption =</span> <span class="st" style="color: #20794D;">"Paramètres de Montana par période de retour"</span>,</span>
<span id="cb4-32">  <span class="at" style="color: #657422;">col.names =</span> <span class="fu" style="color: #4758AB;">c</span>(<span class="st" style="color: #20794D;">"T (ans)"</span>, <span class="st" style="color: #20794D;">"a"</span>, <span class="st" style="color: #20794D;">"b"</span>, <span class="st" style="color: #20794D;">"R²"</span>)</span>
<span id="cb4-33">)</span></code></pre></div>
</details>
