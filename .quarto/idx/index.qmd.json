{"markdown":{"yaml":{"title":"","pagetitle":"NEBIE Gaston Cyrille | Ingénieur Hydrologue","format":{"html":{"toc":false}}},"containsRefs":false,"markdown":"\n\n<!-- ============================================================ -->\n<!-- HERO                                                          -->\n<!-- ============================================================ -->\n<div class=\"hero-section\">\n<div class=\"container py-4\">\n<div class=\"row align-items-center g-5\">\n\n<div class=\"col-lg-7\">\n  <p class=\"hero-subtitle\">Ingénieur Hydrologue &nbsp;·&nbsp; Expert Risques Climatiques</p>\n  <h1 class=\"hero-title\">NEBIE<br><span>Gaston Cyrille</span></h1>\n  <p class=\"hero-tagline\">\n    Analyste des risques hydrologiques et climatiques, spécialiste en SIG \n    et science des données appliquée à la gestion intégrée des ressources \n    en eau en Afrique de l'Ouest.\n  </p>\n  <div style=\"display:flex;gap:0.75rem;flex-wrap:wrap;\">\n    <a href=\"projects/index.html\" class=\"btn btn-primary btn-lg px-4\">Voir mes projets</a>\n    <a href=\"about.html\" class=\"btn btn-outline-info btn-lg px-4\">À propos</a>\n    <a href=\"assets/cv/cv_nebie_2026.pdf\" class=\"btn btn-outline-secondary btn-lg px-4\" target=\"_blank\">\n      ↓ CV\n    </a>\n  </div>\n</div>\n\n<div class=\"col-lg-5 text-center\">\n  <img src=\"assets/img/photo.jpg\" \n       class=\"profile-img\" \n       alt=\"NEBIE Gaston Cyrille – Ingénieur Hydrologue\"\n       onerror=\"this.parentElement.innerHTML='<div class=\\'profile-img-placeholder\\'>💧</div>'\">\n</div>\n\n</div><!-- /row -->\n\n<!-- Stats -->\n<div class=\"row g-3 mt-4\">\n  <div class=\"col-6 col-md-3\">\n    <div class=\"stat-card\">\n      <span class=\"stat-number\">5+</span>\n      <span class=\"stat-label\">Années d'expérience</span>\n    </div>\n  </div>\n  <div class=\"col-6 col-md-3\">\n    <div class=\"stat-card\">\n      <span class=\"stat-number\">8+</span>\n      <span class=\"stat-label\">Projets réalisés</span>\n    </div>\n  </div>\n  <div class=\"col-6 col-md-3\">\n    <div class=\"stat-card\">\n      <span class=\"stat-number\">12+</span>\n      <span class=\"stat-label\">Publications RPubs</span>\n    </div>\n  </div>\n  <div class=\"col-6 col-md-3\">\n    <div class=\"stat-card\">\n      <span class=\"stat-number\">🏆</span>\n      <span class=\"stat-label\">Prix Trophées Eau 2024</span>\n    </div>\n  </div>\n</div>\n\n</div><!-- /container -->\n</div><!-- /hero -->\n\n\n<!-- ============================================================ -->\n<!-- PROJETS PHARES                                                -->\n<!-- ============================================================ -->\n<div class=\"container py-5\">\n\n<div class=\"section-header\">\n  <div class=\"section-label\">Réalisations</div>\n  <h2 class=\"section-main-title\">Projets phares</h2>\n  <div class=\"section-divider\"></div>\n  <p class=\"text-muted-blue mt-2\">Des projets concrets mêlant données hydrologiques, SIG et intelligence artificielle.</p>\n</div>\n\n<div class=\"row g-4\">\n\n  <div class=\"col-md-4\">\n  <div class=\"project-card\">\n    <div class=\"project-icon\">🛰️</div>\n    <div class=\"project-title\">Télédétection avec R</div>\n    <div class=\"project-desc\">\n      Classification non supervisée (K-means) d'images Landsat 8 sur la \n      commune de Bama, Burkina Faso. Utilisation des packages terra, \n      cluster et ggplot2.\n    </div>\n    <div class=\"project-footer\">\n      <span class=\"tag tag-r\">R</span>\n      <span class=\"tag tag-sig\">Télédétection</span>\n      <span class=\"tag tag-ml\">K-means</span>\n      <a href=\"projects/teledetection.html\" class=\"btn btn-sm btn-outline-info mt-2 w-100\">Voir le projet →</a>\n    </div>\n  </div>\n  </div>\n\n  <div class=\"col-md-4\">\n  <div class=\"project-card\">\n    <div class=\"project-icon\">🤖</div>\n    <div class=\"project-title\">IA pour la cartographie aquifère</div>\n    <div class=\"project-desc\">\n      Première utilisation du machine learning (Random Forest, régression \n      logistique) pour la cartographie du potentiel aquifère en zone de \n      socle au Burkina Faso.\n    </div>\n    <div class=\"project-footer\">\n      <span class=\"tag tag-ml\">Machine Learning</span>\n      <span class=\"tag tag-sig\">SIG</span>\n      <span class=\"tag tag-r\">R</span>\n      <a href=\"projects/ml-aquifere.html\" class=\"btn btn-sm btn-outline-info mt-2 w-100\">Voir le projet →</a>\n    </div>\n  </div>\n  </div>\n\n  <div class=\"col-md-4\">\n  <div class=\"project-card\">\n    <div class=\"project-icon\">🌊</div>\n    <div class=\"project-title\">Scénarios hydrologiques du Nakanbé</div>\n    <div class=\"project-desc\">\n      Modélisation hydrologique du bassin versant du Nakanbé avec les \n      modèles GR4J, GR6J et SWAT. Correction de biais et production de \n      scénarios CMIP6.\n    </div>\n    <div class=\"project-footer\">\n      <span class=\"tag tag-water\">Hydrologie</span>\n      <span class=\"tag tag-climate\">CMIP6</span>\n      <span class=\"tag tag-r\">R</span>\n      <a href=\"projects/modelisation-nakambe.html\" class=\"btn btn-sm btn-outline-info mt-2 w-100\">Voir le projet →</a>\n    </div>\n  </div>\n  </div>\n\n</div><!-- /row -->\n\n<div class=\"text-center mt-4\">\n  <a href=\"projects/index.html\" class=\"btn btn-outline-primary px-5\">\n    Voir tous les projets →\n  </a>\n</div>\n\n</div><!-- /container -->\n\n\n<!-- ============================================================ -->\n<!-- DISTINCTION                                                   -->\n<!-- ============================================================ -->\n<div style=\"background:#050d1a;padding:4rem 0;border-top:1px solid #1a3a6b;border-bottom:1px solid #1a3a6b;\">\n<div class=\"container\">\n<div class=\"row justify-content-center\">\n<div class=\"col-lg-8\">\n\n<div class=\"award-card\">\n  <div class=\"award-year\">2024</div>\n  <div style=\"font-size:0.72rem;text-transform:uppercase;letter-spacing:0.15em;color:#ffd166;font-weight:700;margin-bottom:0.5rem;\">\n    🏆 Distinction\n  </div>\n  <div class=\"award-title\">Prix des Pratiques Innovantes</div>\n  <div class=\"award-org\">\n    3ème édition des Trophées de l'Eau et de l'Assainissement du Burkina Faso\n  </div>\n  <p style=\"font-size:0.9rem;color:#90a8c0;margin:0;max-width:540px;\">\n    Récompense pour l'application de méthodes d'intelligence artificielle \n    à la cartographie des ressources en eau en zone de socle.\n  </p>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n\n<!-- ============================================================ -->\n<!-- DERNIERS ARTICLES                                             -->\n<!-- ============================================================ -->\n<div class=\"container py-5\">\n\n<div class=\"section-header\">\n  <div class=\"section-label\">Blog</div>\n  <h2 class=\"section-main-title\">Derniers tutoriels R</h2>\n  <div class=\"section-divider\"></div>\n</div>\n\n<div class=\"row g-3\">\n  <div class=\"col-md-4\">\n    <div class=\"pub-item\">\n      <div class=\"pub-type pub-type-rpubs\">Tutoriel R</div>\n      <div class=\"pub-title\">Réalisation de courbes IDF avec R</div>\n      <div class=\"pub-meta\">Analyse fréquentielle des précipitations extrêmes</div>\n      <a href=\"blog/posts/idf-curves-r/index.html\" class=\"btn btn-sm btn-outline-secondary mt-2\">Lire →</a>\n    </div>\n  </div>\n  <div class=\"col-md-4\">\n    <div class=\"pub-item\">\n      <div class=\"pub-type pub-type-rpubs\">Tutoriel R</div>\n      <div class=\"pub-title\">Classification K-means Landsat 8</div>\n      <div class=\"pub-meta\">Télédétection non supervisée avec terra et cluster</div>\n      <a href=\"blog/posts/kmeans-landsat/index.html\" class=\"btn btn-sm btn-outline-secondary mt-2\">Lire →</a>\n    </div>\n  </div>\n  <div class=\"col-md-4\">\n    <div class=\"pub-item\">\n      <div class=\"pub-type pub-type-rpubs\">Tutoriel R</div>\n      <div class=\"pub-title\">Correction de biais des scénarios climatiques</div>\n      <div class=\"pub-meta\">Post-traitement des données CMIP avec R</div>\n      <a href=\"blog/posts/biais-correction/index.html\" class=\"btn btn-sm btn-outline-secondary mt-2\">Lire →</a>\n    </div>\n  </div>\n</div>\n\n<div class=\"text-center mt-4\">\n  <a href=\"blog/index.html\" class=\"btn btn-outline-primary px-5\">Voir tous les articles →</a>\n</div>\n\n</div><!-- /container -->\n\n\n<!-- ============================================================ -->\n<!-- ASSOCIATIONS & RÉSEAUX                                        -->\n<!-- ============================================================ -->\n<div style=\"background:#050d1a;padding:3rem 0;border-top:1px solid #1a3a6b;\">\n<div class=\"container text-center\">\n  <p class=\"text-muted-blue mb-3\" style=\"font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;\">\n    Engagement associatif & académique\n  </p>\n  <div class=\"d-flex justify-content-center align-items-center gap-4 flex-wrap\">\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-radius:0.5rem;padding:0.75rem 1.5rem;color:#cdd6f4;font-size:0.9rem;font-weight:500;\">\n      💧 Vice-Président — Association Hydro-Burkina\n    </div>\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-radius:0.5rem;padding:0.75rem 1.5rem;color:#cdd6f4;font-size:0.9rem;font-weight:500;\">\n      🎓 Master GRC — Université de Liège, Belgique\n    </div>\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-radius:0.5rem;padding:0.75rem 1.5rem;color:#cdd6f4;font-size:0.9rem;font-weight:500;\">\n      📊 CRA Agrhymet — Ingénieur Hydrologue\n    </div>\n  </div>\n</div>\n</div>\n"},"formats":{"html":{"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":"auto","echo":true,"output":true,"warning":false,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null