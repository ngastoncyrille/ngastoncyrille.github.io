{"title":"Contact","markdown":{"yaml":{"title":"Contact","subtitle":"N'hésitez pas à me contacter pour toute question ou opportunité de collaboration","format":{"html":{"toc":false}}},"containsRefs":false,"markdown":"\n\n```{=html}\n<div class=\"row g-5 mt-2\">\n\n<!-- ── Coordonnées ── -->\n<div class=\"col-md-6\">\n\n<h3 class=\"text-water mb-4\">Coordonnées</h3>\n\n<a href=\"https://www.linkedin.com/in/gaston-cyrille-nebie-a2a977222\" \n   target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">in</div>\n  <div>\n    <div class=\"contact-label\">LinkedIn</div>\n    <div class=\"contact-value\">Gaston Cyrille NEBIE</div>\n  </div>\n</a>\n\n<a href=\"https://github.com/ngastoncyrille\" target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">⌥</div>\n  <div>\n    <div class=\"contact-label\">GitHub</div>\n    <div class=\"contact-value\">ngastoncyrille</div>\n  </div>\n</a>\n\n<a href=\"https://rpubs.com/nebiegc\" target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">📊</div>\n  <div>\n    <div class=\"contact-label\">RPubs</div>\n    <div class=\"contact-value\">rpubs.com/nebiegc</div>\n  </div>\n</a>\n\n\n<div style=\"text-align:center;margin-top:2rem;padding:1.5rem;background:#f4f8fb;border-radius:0.75rem;border:1px solid #d0e4f0;\">\n  <p style=\"font-size:0.8rem;color:#6a8aaa;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem;\">\n    Localisation actuelle\n  </p>\n  <p style=\"font-size:1.05rem;color:#023e8a;font-weight:600;margin-bottom:0.25rem;\">\n    🇧🇪 Liège, Belgique &nbsp;/&nbsp; 🇧🇫 Ouagadougou, Burkina Faso\n  </p>\n  <p style=\"font-size:0.88rem;color:#6a8aaa;margin:0;\">\n    Disponible pour des missions en présentiel ou à distance\n  </p>\n</div>\n\n</div><!-- /col coordonnées -->\n\n<!-- ── Formulaire ── -->\n<div class=\"col-md-6\">\n\n<h3 class=\"text-water mb-4\">Formulaire de contact</h3>\n\n<p style=\"font-size:0.88rem;color:#6a8aaa;margin:0;\">\n    Disponible pour des missions en présentiel ou à distance\n  </p>\n\n<div style=\"background:#ffffff;border:1px solid #d0e4f0;border-radius:0.75rem;padding:1.75rem;box-shadow:0 2px 16px rgba(0,119,182,0.07);\">\n\n<form action=\"https://formspree.io/f/mqewqrwv\" method=\"POST\">\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#4a6a80;display:block;margin-bottom:0.4rem;font-weight:500;\">\n      Nom complet\n    </label>\n    <input type=\"text\" name=\"nom\" required\n           style=\"width:100%;padding:0.6rem 0.9rem;background:#f4f8fb;border:1px solid #c8dff0;\n                  border-radius:0.4rem;color:#1a2e42;font-size:0.95rem;outline:none;\"\n           placeholder=\"Votre nom\">\n  </div>\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#4a6a80;display:block;margin-bottom:0.4rem;font-weight:500;\">\n      Adresse email\n    </label>\n    <input type=\"email\" name=\"email\" required\n           style=\"width:100%;padding:0.6rem 0.9rem;background:#f4f8fb;border:1px solid #c8dff0;\n                  border-radius:0.4rem;color:#1a2e42;font-size:0.95rem;outline:none;\"\n           placeholder=\"votre@email.com\">\n  </div>\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#4a6a80;display:block;margin-bottom:0.4rem;font-weight:500;\">\n      Sujet\n    </label>\n    <select name=\"sujet\"\n            style=\"width:100%;padding:0.6rem 0.9rem;background:#f4f8fb;border:1px solid #c8dff0;\n                   border-radius:0.4rem;color:#1a2e42;font-size:0.95rem;\">\n      <option value=\"collaboration\">Collaboration / Projet</option>\n      <option value=\"consultation\">Mission de consultation</option>\n      <option value=\"formation\">Formation / Renforcement de capacités</option>\n      <option value=\"recherche\">Recherche / Partenariat académique</option>\n      <option value=\"autre\">Autre</option>\n    </select>\n  </div>\n\n  <div style=\"margin-bottom:1.5rem;\">\n    <label style=\"font-size:0.85rem;color:#4a6a80;display:block;margin-bottom:0.4rem;font-weight:500;\">\n      Message\n    </label>\n    <textarea name=\"message\" required rows=\"5\"\n              style=\"width:100%;padding:0.6rem 0.9rem;background:#f4f8fb;border:1px solid #c8dff0;\n                     border-radius:0.4rem;color:#1a2e42;font-size:0.95rem;resize:vertical;\"\n              placeholder=\"Décrivez votre demande...\"></textarea>\n  </div>\n\n  <button type=\"submit\" \n          style=\"width:100%;padding:0.75rem;background:#0077b6;border:none;border-radius:0.4rem;\n                 color:white;font-size:1rem;font-weight:600;cursor:pointer;\n                 transition:background 0.2s;\"\n          onmouseover=\"this.style.background='#005f8e'\"\n          onmouseout=\"this.style.background='#0077b6'\">\n    ✉ Envoyer le message\n  </button>\n\n</form>\n\n<p style=\"font-size:0.8rem;color:#8aacbf;margin-top:1rem;text-align:center;\">\n  ⚡ Alimenté par <a href=\"https://formspree.io\" target=\"_blank\" style=\"color:#0077b6;\">Formspree</a> · Réponse sous 48h\n</p>\n\n</div><!-- /form card -->\n\n</div><!-- /col formulaire -->\n\n</div><!-- /row -->\n```\n"},"formats":{"html":{"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":"auto","echo":true,"output":true,"warning":false,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"message":false,"engine":"markdown"},"render":{"keep-tex":false,"keep-yaml":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"center","fig-pos":null,"fig-env":null,"code-fold":true,"code-overflow":"scroll","code-link":false,"code-line-numbers":false,"code-tools":true,"tbl-colwidths":"auto","merge-includes":true,"latex-auto-mk":true,"latex-auto-install":true,"latex-clean":true,"latex-max