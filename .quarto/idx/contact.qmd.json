{"title":"Contact","markdown":{"yaml":{"title":"Contact","subtitle":"N'hésitez pas à me contacter pour toute question ou opportunité de collaboration","format":{"html":{"toc":false}}},"containsRefs":false,"markdown":"\n\n<div class=\"row g-5 mt-2\">\n\n<div class=\"col-md-6\">\n\n<h3 class=\"text-water mb-4\">Coordonnées</h3>\n\n<a href=\"mailto:ngastoncyrille@gmail.com\" class=\"contact-card\">\n  <div class=\"contact-icon\">✉</div>\n  <div>\n    <div class=\"contact-label\">Email</div>\n    <div class=\"contact-value\">ngastoncyrille@gmail.com</div>\n  </div>\n</a>\n\n<a href=\"https://www.linkedin.com/in/gaston-cyrille-nebie-a2a977222\" \n   target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">in</div>\n  <div>\n    <div class=\"contact-label\">LinkedIn</div>\n    <div class=\"contact-value\">Gaston Cyrille NEBIE</div>\n  </div>\n</a>\n\n<a href=\"https://github.com/ngastoncyrille\" target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">⌥</div>\n  <div>\n    <div class=\"contact-label\">GitHub</div>\n    <div class=\"contact-value\">ngastoncyrille</div>\n  </div>\n</a>\n\n<a href=\"https://rpubs.com/nebiegc\" target=\"_blank\" class=\"contact-card\">\n  <div class=\"contact-icon\">📊</div>\n  <div>\n    <div class=\"contact-label\">RPubs</div>\n    <div class=\"contact-value\">rpubs.com/nebiegc</div>\n  </div>\n</a>\n\n<div style=\"background:#112240;border:1px solid #1a3a6b;border-radius:0.65rem;padding:1.25rem;margin-top:1.5rem;\">\n  <div style=\"font-size:0.75rem;color:#48cae4;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem;\">\n    💧 Association Hydro-Burkina\n  </div>\n  <div style=\"font-size:0.9rem;color:#90a8c0;\">\n    Vice-Président · Production et diffusion d'information sur l'eau et le climat en \n    Afrique de l'Ouest\n  </div>\n</div>\n\n</div><!-- /col -->\n\n<div class=\"col-md-6\">\n\n<h3 class=\"text-water mb-4\">Formulaire de contact</h3>\n\n<div style=\"background:#112240;border:1px solid #1a3a6b;border-radius:0.75rem;padding:1.75rem;\">\n\n<form action=\"https://formspree.io/f/VOTRE_ID_FORMSPREE\" method=\"POST\">\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#90a8c0;display:block;margin-bottom:0.4rem;\">\n      Nom complet\n    </label>\n    <input type=\"text\" name=\"nom\" required\n           style=\"width:100%;padding:0.6rem 0.9rem;background:#0d1b2a;border:1px solid #1a3a6b;\n                  border-radius:0.4rem;color:#cdd6f4;font-size:0.95rem;\"\n           placeholder=\"Votre nom\">\n  </div>\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#90a8c0;display:block;margin-bottom:0.4rem;\">\n      Adresse email\n    </label>\n    <input type=\"email\" name=\"email\" required\n           style=\"width:100%;padding:0.6rem 0.9rem;background:#0d1b2a;border:1px solid #1a3a6b;\n                  border-radius:0.4rem;color:#cdd6f4;font-size:0.95rem;\"\n           placeholder=\"votre@email.com\">\n  </div>\n\n  <div style=\"margin-bottom:1rem;\">\n    <label style=\"font-size:0.85rem;color:#90a8c0;display:block;margin-bottom:0.4rem;\">\n      Sujet\n    </label>\n    <select name=\"sujet\"\n            style=\"width:100%;padding:0.6rem 0.9rem;background:#0d1b2a;border:1px solid #1a3a6b;\n                   border-radius:0.4rem;color:#cdd6f4;font-size:0.95rem;\">\n      <option value=\"collaboration\">Collaboration / Projet</option>\n      <option value=\"consultation\">Mission de consultation</option>\n      <option value=\"formation\">Formation / Renforcement de capacités</option>\n      <option value=\"recherche\">Recherche / Partenariat académique</option>\n      <option value=\"autre\">Autre</option>\n    </select>\n  </div>\n\n  <div style=\"margin-bottom:1.5rem;\">\n    <label style=\"font-size:0.85rem;color:#90a8c0;display:block;margin-bottom:0.4rem;\">\n      Message\n    </label>\n    <textarea name=\"message\" required rows=\"5\"\n              style=\"width:100%;padding:0.6rem 0.9rem;background:#0d1b2a;border:1px solid #1a3a6b;\n                     border-radius:0.4rem;color:#cdd6f4;font-size:0.95rem;resize:vertical;\"\n              placeholder=\"Décrivez votre demande...\"></textarea>\n  </div>\n\n  <button type=\"submit\" \n          style=\"width:100%;padding:0.75rem;background:#0077b6;border:none;border-radius:0.4rem;\n                 color:white;font-size:1rem;font-weight:600;cursor:pointer;\n                 transition:background 0.2s;\"\n          onmouseover=\"this.style.background='#00b4d8'\"\n          onmouseout=\"this.style.background='#0077b6'\">\n    Envoyer le message\n  </button>\n\n</form>\n\n<p style=\"font-size:0.8rem;color:#5a7090;margin-top:1rem;text-align:center;\">\n  ⚡ Alimenté par Formspree · Réponse sous 48h\n</p>\n\n</div>\n\n</div><!-- /col -->\n\n</div><!-- /row -->\n\n---\n\n<div class=\"text-center mt-4\" style=\"padding:2rem;\">\n  <p class=\"text-muted-blue\" style=\"font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;\">\n    Localisation actuelle\n  </p>\n  <p style=\"font-size:1.1rem;color:#90e0ef;font-weight:500;\">\n    🇧🇪 Liège, Belgique &nbsp;/&nbsp; 🇧🇫 Ouagadougou, Burkina Faso\n  </p>\n  <p style=\"font-size:0.9rem;color:#7090a0;\">\n    Disponible pour des missions en présentiel ou à distance\n  </p>\n</div>\n"},"formats":{"html":{"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":"auto","echo":true,"output":true,"warning":false,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"message":false,"engine":"markdown"},"render":{"keep-tex":false,"keep-yaml":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"center","fig-pos":null,"fig-env":null,"code-fold":true,"code-overflow":"scroll","code-link":false,