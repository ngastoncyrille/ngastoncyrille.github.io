width:68%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>SQL (bases de données)</span><span class=\"skill-pct\">65%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:65%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>R Markdown / Quarto</span><span class=\"skill-pct\">85%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:85%\"></div></div>\n</div>\n\n</div><!-- /skill-group -->\n\n<div class=\"skill-group\">\n<div class=\"skill-category-label\">SIG & Télédétection</div>\n\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>QGIS</span><span class=\"skill-pct\">85%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:85%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>ArcGIS</span><span class=\"skill-pct\">80%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:80%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Google Earth Engine</span><span class=\"skill-pct\">70%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:70%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>R (terra, sf, stars)</span><span class=\"skill-pct\">82%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:82%\"></div></div>\n</div>\n\n</div><!-- /skill-group -->\n</div><!-- /col-md-6 -->\n\n<div class=\"col-md-6\">\n\n<div class=\"skill-group\">\n<div class=\"skill-category-label\">Modélisation hydrologique</div>\n\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Modèles GR4J / GR6J (airGR)</span><span class=\"skill-pct\">88%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:88%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>SWAT</span><span class=\"skill-pct\">72%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:72%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Analyse fréquentielle (IDF, crues)</span><span class=\"skill-pct\">85%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:85%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Scénarios climatiques (NetCDF, CMIP6)</span><span class=\"skill-pct\">80%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:80%\"></div></div>\n</div>\n\n</div><!-- /skill-group -->\n\n<div class=\"skill-group\">\n<div class=\"skill-category-label\">Machine Learning & BI</div>\n\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Random Forest, Arbres de décision</span><span class=\"skill-pct\">78%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:78%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Régression logistique</span><span class=\"skill-pct\">75%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:75%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>Power BI / Looker Studio</span><span class=\"skill-pct\">68%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:68%\"></div></div>\n</div>\n<div class=\"skill-item\">\n  <div class=\"skill-name\"><span>ggplot2 / plotly / leaflet</span><span class=\"skill-pct\">85%</span></div>\n  <div class=\"skill-bar\"><div class=\"skill-fill\" style=\"width:85%\"></div></div>\n</div>\n\n</div><!-- /skill-group -->\n\n</div><!-- /col-md-6 -->\n</div><!-- /row -->\n\n---\n\n## 📦 Packages R principaux\n\n\n::: {.cell}\n::: {.cell-output-display}\n![](skills_files/figure-html/packages-r-1.png){width=672}\n:::\n:::\n\n\n---\n\n## 🌊 Domaines thématiques\n\n<div class=\"row g-3\">\n  <div class=\"col-md-6\">\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-left:4px solid #00b4d8;border-radius:0.5rem;padding:1.25rem;\">\n      <h5 style=\"color:#90e0ef;margin-bottom:0.75rem;\">Gestion des Risques & Catastrophes</h5>\n      <ul style=\"color:#90a8c0;font-size:0.9rem;padding-left:1.25rem;margin:0;\">\n        <li>Analyse des aléas hydrologiques et climatiques</li>\n        <li>Cartographie et analyse spatiale des risques</li>\n        <li>Analyse des vulnérabilités territoriales</li>\n        <li>Préparation et planification des risques</li>\n        <li>Systèmes d'alerte précoce</li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"col-md-6\">\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-left:4px solid #06d6a0;border-radius:0.5rem;padding:1.25rem;\">\n      <h5 style=\"color:#90e0ef;margin-bottom:0.75rem;\">Analyse Hydroclimatique</h5>\n      <ul style=\"color:#90a8c0;font-size:0.9rem;padding-left:1.25rem;margin:0;\">\n        <li>Analyse de séries hydroclimatiques</li>\n        <li>Variabilité et tendances climatiques</li>\n        <li>Événements extrêmes — crues, sécheresses</li>\n        <li>Correction de biais (scénarios CMIP6)</li>\n        <li>Agroclimatologie (saisons, séquences sèches)</li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"col-md-6\">\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-left:4px solid #f4a261;border-radius:0.5rem;padding:1.25rem;\">\n      <h5 style=\"color:#90e0ef;margin-bottom:0.75rem;\">SIG & Télédétection</h5>\n      <ul style=\"color:#90a8c0;font-size:0.9rem;padding-left:1.25rem;margin:0;\">\n        <li>Cartographie des ressources en eau</li>\n        <li>Classification d'images satellitaires (Landsat)</li>\n        <li>Analyse du potentiel aquifère</li>\n        <li>Morphométrie des bassins versants</li>\n        <li>Spatialisation des données climatiques</li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"col-md-6\">\n    <div style=\"background:#112240;border:1px solid #1a3a6b;border-left:4px solid #c4b5fd;border-radius:0.5rem;padding:1.25rem;\">\n      <h5 style=\"color:#90e0ef;margin-bottom:0.75rem;\">GIRE & Approches participatives</h5>\n      <ul style=\"color:#90a8c0;font-size:0.9rem;padding-left:1.25rem;margin:0;\">\n        <li>Gestion Intégrée des Ressources en Eau</li>\n        <li>Diagnostic participatif</li>\n        <li>Planification territoriale</li>\n        <li>Renforcement des capacités</li>\n        <li>Suivi-évaluation de projets</li>\n      </ul>\n    </div>\n  </div>\n</div>\n",
